<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Standard Material theme for Compose activity -->
    <style name="Theme.ContinueX" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#080C14</item>
        <item name="android:windowBackground">#080C14</item>
    </style>

    <!-- Splash Screen theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#080C14</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <item name="postSplashScreenTheme">@style/Theme.ContinueX</item>
    </style>
</resources>